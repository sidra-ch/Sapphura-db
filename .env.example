# Production-safe environment template for Sapphura.
# Fill these with real values in your local .env/.env.local or your hosting provider.

# Core app
APP_URL=https://your-domain.com
NODE_ENV=production
DATABASE_URL=
JWT_SECRET=

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_ADMIN_EMAILS=
ADMIN_EMAILS=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Wallet payments
EASYPAISA_INITIATE_URL=
EASYPAISA_STATUS_URL=
EASYPAISA_SECRET=
JAZZCASH_INITIATE_URL=
JAZZCASH_STATUS_URL=
JAZZCASH_INTEGRITY_SALT=

# Payment tools
PAYMENT_RECONCILE_KEY=
PAYMENT_DEBUG_KEY=

# Email / SMTP
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Optional legacy email aliases
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Meta Pixel
NEXT_PUBLIC_META_PIXEL_ID=

# Optional fraud provider
FRAUD_PROVIDER_ENDPOINT=
FRAUD_PROVIDER_API_KEY=

# OTP behavior
OTP_EMAIL_ONLY_MODE=true

# Optional seed defaults
ADMIN_DEFAULT_EMAIL=
ADMIN_DEFAULT_PASSWORD=
ADMIN_DEFAULT_NAME=
ADMIN_DEFAULT_PHONE=